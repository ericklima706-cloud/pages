<script>
  // Número e mensagem de boas-vindas
  var phone   = "5531986804625";
  var message = "Oii Rose, tudo bem ?? Quero fazer minhas fotos com você, do que eu preciso ??";

  var url = "https://wa.me/" + phone + "?text=" + encodeURIComponent(message);
